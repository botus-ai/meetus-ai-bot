# Meetus AI Bot — Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# REQUIRED
# ============================================================

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Your Telegram user ID (get from @userinfobot)
MEETUS_ADMIN_ID=your_telegram_user_id

# ============================================================
# TRANSCRIPTION (choose at least one)
# ============================================================

# Provider: auto, groq, openai, local_whisper
TRANSCRIBE_PROVIDER=auto

# Groq (free tier available): https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (Whisper): https://platform.openai.com
OPENAI_API_KEY=sk-your_openai_key_here

# Local Whisper model: tiny, base, small, medium, large, turbo
LOCAL_WHISPER_MODEL=turbo

# ============================================================
# ANALYSIS
# ============================================================

# Provider: openclaw, openai_compatible
ANALYSIS_PROVIDER=openclaw

# For OpenClaw integration
OPENCLAW_AGENT=meetus

# ============================================================
# BUSINESS SETTINGS
# ============================================================

# SQLite database path
DB_PATH=data/meetus.db

# Free uses per new user
TRIAL_LIMIT=3

# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50
